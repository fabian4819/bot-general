# Google Sheets Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
SPREADSHEET_ID=
# Optional manual mappings: phone:spreadsheetId,phone:spreadsheetId
USER_SPREADSHEETS=

# Invoice log: per-number mapping takes priority, global ID is the fallback
INVOICE_SPREADSHEET_ID=
INVOICE_USER_SPREADSHEETS=

# DeepSeek API
DEEPSEEK_API_KEY=sk-...

# Bot Config
OWNER_PHONE=628xxxxxxxxxx
ALLOWED_PHONES=628xxx,628yyy   # comma-separated, bot hanya merespons nomor ini
SESSION_PATH=./auth_info_baileys
TIMEZONE=Asia/Jakarta

# Google Drive OAuth2 (untuk upload invoice ke Drive)
# Dapatkan dengan: npx tsx scripts/setup-drive-auth.ts
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
